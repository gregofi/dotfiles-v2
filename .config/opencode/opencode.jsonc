{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "edit": "allow",
    "grep": "allow",
    "glob": "allow",
    "list": "allow",
    "bash": "ask",
    "webfetch": "ask",
    "bash": {
      "*": "ask",

      "git log *": "allow",
      "git show *": "allow",
      "git status *": "allow",
      "grep *": "allow",
      "find *": "allow",
      "ls *": "allow",
    },
  }
}
